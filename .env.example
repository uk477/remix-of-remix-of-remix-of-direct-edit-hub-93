# ────────────────────────────────────────────────────────────
#  Лови это как шпаргалку. Скопируй файл в `.env`
#  и подставь свои значения. Все переменные опциональны —
#  если не задать, используются дефолты из src/fanvue/config.ts
#
#  Ссылки/контакты/отзывы лучше менять прямо в админ-панели:
#     /admin/settings → "Ссылки и контакты"
#  (изменения применяются мгновенно, без пересборки).
# ────────────────────────────────────────────────────────────

# Брендинг
VITE_BRAND_NAME=FANVUE MARKET
VITE_BRAND_SUBTITLE=MARKET · 2.0

# Telegram-юзернеймы (без @)
VITE_BOT_USERNAME=FanvueMarketBot
VITE_ADMIN_USERNAME=FanvueAdmin
VITE_SUPPORT_USERNAME=FanvueSupport
VITE_CHANNEL_USERNAME=FanvueStore
VITE_COMMUNITY_USERNAME=FanvueCommunity

# Список admin uid через запятую
VITE_ADMIN_IDS=123456789

# Внешние URL
VITE_SITE_URL=
VITE_API_URL=

# Крипто-кошельки (можно так же редактировать в /admin/settings)
VITE_ADDR_TRC20=
VITE_ADDR_ERC20=
VITE_ADDR_BEP20=
VITE_ADDR_ETH=
VITE_ADDR_SOL=
VITE_ADDR_BTC=
VITE_ADDR_USDC_ETH=
VITE_ADDR_USDC_SOL=

# Параметры
VITE_PAYMENT_TIMEOUT_MINUTES=30
VITE_REF_BONUS_PCT=5
VITE_BULK_DISCOUNT_PCT=5
VITE_BULK_DISCOUNT_MIN_QTY=3
VITE_POLL_INTERVAL_MS=6000