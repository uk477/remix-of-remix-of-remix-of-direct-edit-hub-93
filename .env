# ════════════════════════════════════════════════════════════
#  ГЛАВНЫЙ ФАЙЛ КОНФИГУРАЦИИ — меняй здесь свои данные.
#  После редактирования нужен ПЕРЕЗАПУСК сборки (Vite читает
#  переменные на старте). В Lovable это происходит автоматически.
#
#  Все ссылки/контакты также можно править на лету в
#  админ-панели: /admin/settings → "Ссылки и контакты".
# ════════════════════════════════════════════════════════════

# ── Брендинг ────────────────────────────────────────────────
VITE_BRAND_NAME=FANVUE MARKET
VITE_BRAND_SUBTITLE=MARKET · 2.0

# ── Telegram-юзернеймы (БЕЗ символа @) ──────────────────────
# Бот магазина (ссылка t.me/<тут>)
VITE_BOT_USERNAME=FanvueMarketBot
# Твой личный аккаунт-админ (связь по заказам)
VITE_ADMIN_USERNAME=FanvueAdmin
# Аккаунт/бот поддержки — именно он открывается в "Открыть в Telegram"
VITE_SUPPORT_USERNAME=FanvueSupport
# Канал с новостями / отзывами
VITE_CHANNEL_USERNAME=FanvueStore
# Чат-сообщество
VITE_COMMUNITY_USERNAME=FanvueCommunity

# ── Telegram user-ID админов (через запятую, без пробелов) ──
# Эти UID получают доступ к /admin
VITE_ADMIN_IDS=123456789

# ── Внешние URL ─────────────────────────────────────────────
# Публичный сайт (для шаринга / og-тегов)
VITE_SITE_URL=
# Бэкенд API. Пусто = демо-режим (имитация оплаты)
VITE_API_URL=

# ── Крипто-кошельки для приёма оплаты ───────────────────────
# Можно также менять в /admin/settings → "Крипто-адреса"
VITE_ADDR_TRC20=
VITE_ADDR_ERC20=
VITE_ADDR_BEP20=
VITE_ADDR_ETH=
VITE_ADDR_SOL=
VITE_ADDR_BTC=
VITE_ADDR_USDC_ETH=
VITE_ADDR_USDC_SOL=

# ── Бизнес-параметры ────────────────────────────────────────
# Сколько минут даём пользователю на оплату
VITE_PAYMENT_TIMEOUT_MINUTES=30
# % реферального бонуса
VITE_REF_BONUS_PCT=5
# % скидки при оптовой покупке
VITE_BULK_DISCOUNT_PCT=5
# С какого кол-ва срабатывает оптовая скидка
VITE_BULK_DISCOUNT_MIN_QTY=3
# Как часто опрашивать статус оплаты (мс)
VITE_POLL_INTERVAL_MS=6000